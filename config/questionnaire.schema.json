{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Semantic Onboarding Questionnaire",
  "type": "object",
  "required": ["source_name", "questions"],
  "properties": {
    "source_name": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "question"],
        "properties": {
          "type": { "type": "string" },
          "table": { "type": ["string", "null"] },
          "column": { "type": ["string", "null"] },
          "left_table": { "type": ["string", "null"] },
          "right_table": { "type": ["string", "null"] },
          "question": { "type": "string" },
          "suggested_answer": { "type": ["string", "null"] },
          "suggested_join": { "type": ["string", "null"] },
          "metadata": { "type": "object" },
          "answer": {
            "oneOf": [
              { "type": "string" },
              { "type": "boolean" },
              {
                "type": "array",
                "items": { "type": "string" }
              },
              { "type": "null" }
            ]
          }
        }
      }
    }
  }
}

