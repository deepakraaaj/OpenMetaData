APP_ENV=development
APP_NAME=openmetadata-semantic-onboarding
APP_HOST=127.0.0.1
APP_PORT=8088
WORKSPACE_ROOT=.
CONFIG_DIR=./config
OUTPUT_DIR=./output
APP_METADATA_DATABASE_URL=sqlite+pysqlite:///./output/app_metadata.db
ADMIN_UI_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ADMIN_UI_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|192\\.168\\.\\d{1,3}\\.\\d{1,3}|10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(1[6-9]|2\\d|3[01])\\.\\d{1,3}\\.\\d{1,3})(:\\d+)?$

OPENMETADATA_HOST=http://127.0.0.1:8585/api
OPENMETADATA_HEALTH_URL=http://127.0.0.1:8585
OPENMETADATA_JWT_TOKEN=
OPENMETADATA_INGESTION_BIN=metadata
OPENMETADATA_VERSION=1.12.0
OPENMETADATA_SERVICE_PREFIX=local
OPENMETADATA_ENABLE_SYNC=false

DISCOVERY_SCAN_ROOTS=/home/user/Desktop,/home/user/Downloads,/home/user/Work
DISCOVERY_INCLUDE_HOME=true
DISCOVERY_MAX_FILE_BYTES=524288
DISCOVERY_SKIP_DIRS=.git,node_modules,.venv,venv,dist,build,target,.cache,.cargo,site-packages
