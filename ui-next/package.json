{
  "name": "openmetadata-onboarding-ui",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "node -e \"for (const dir of ['.next', '.next-dev']) require('fs').rmSync(dir, { recursive: true, force: true })\"",
    "dev": "next dev",
    "build": "next build",
    "rebuild": "npm run clean && next build",
    "start": "next start",
    "start:fresh": "npm run clean && next build && next start"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "mermaid": "^11.14.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
